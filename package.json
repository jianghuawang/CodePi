{
  "name": "codepi",
  "version": "0.1.0",
  "private": true,
  "description": "A macOS-first desktop command center for the Pi coding agent",
  "author": "CodePi Contributors",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && electron-vite build",
    "dist:mac": "npm run build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "@tanstack/react-virtual": "3.14.5",
    "dompurify": "3.4.11",
    "lucide-react": "1.24.0",
    "marked": "18.0.6",
    "parse-diff": "0.12.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "4.3.1"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "works.earendil.codepi",
    "productName": "CodePi",
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        },
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSApplicationCategoryType": "public.app-category.developer-tools"
      }
    },
    "dmg": {
      "title": "CodePi ${version}",
      "artifactName": "CodePi-${version}-${arch}.${ext}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 140, "y": 190, "type": "file" },
        { "x": 400, "y": 190, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
