{
  "name": "codepi",
  "version": "0.3.0",
  "private": true,
  "description": "A macOS-first desktop command center for the Pi coding agent",
  "license": "MIT",
  "author": "CodePi Contributors",
  "homepage": "https://github.com/jianghuawang/CodePi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jianghuawang/CodePi.git"
  },
  "bugs": {
    "url": "https://github.com/jianghuawang/CodePi/issues"
  },
  "keywords": [
    "coding-agent",
    "electron",
    "macos",
    "pi",
    "react"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "npm@11.12.1",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js && electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && electron-vite build",
    "build:web": "vite build --config vite.web.config.ts && vite build --config vite.shim.config.ts",
    "check": "npm run lint && npm test && npm run build",
    "dist:mac": "npm run build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/react-virtual": "3.14.5",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "dompurify": "3.4.12",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lucide-react": "1.24.0",
    "marked": "18.0.6",
    "parse-diff": "0.12.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "4.3.1",
    "typescript": "7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "works.earendil.codepi",
    "productName": "CodePi",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "files": [
      "out/**/*",
      "LICENSE",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "minimumSystemVersion": "12.0.0",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSApplicationCategoryType": "public.app-category.developer-tools"
      }
    },
    "dmg": {
      "sign": true,
      "title": "CodePi ${version}",
      "artifactName": "CodePi-${version}-${arch}.${ext}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190,
          "type": "file"
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
